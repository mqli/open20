{
  "name": "open20",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "build-storybook": "turbo run build-storybook",
    "dev": "turbo run dev --parallel",
    "storybook": "pnpm --filter @open20/ui storybook",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@open20/config": "workspace:*",
    "@eslint/js": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "turbo": "latest",
    "typescript-eslint": "catalog:"
  },
  "packageManager": "pnpm@10.17.1"
}
