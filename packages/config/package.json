{
  "name": "@open20/config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "exports": {
    "./eslint": "./eslint/index.js",
    "./postcss": "./postcss/index.js",
    "./vite": {
      "types": "./types/vite/index.d.ts",
      "default": "./vite/index.js"
    },
    "./vitest": {
      "types": "./types/vitest/index.d.ts",
      "default": "./vitest/index.js"
    },
    "./vitest/utils": {
      "types": "./types/vitest/utils.d.ts",
      "default": "./vitest/utils.ts"
    },
    "./storybook": {
      "types": "./types/storybook/index.d.ts",
      "default": "./storybook/index.js"
    },
    "./tsconfig/base.json": "./tsconfig/base.json",
    "./tsconfig/react-app.json": "./tsconfig/react-app.json",
    "./tsconfig/library.json": "./tsconfig/library.json"
  },
  "dependencies": {
    "@eslint/js": "catalog:",
    "eslint-plugin-unused-imports": "catalog:",
    "globals": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  }
}
