{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "types": ["node"],
    "outDir": "./types",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["vite/**/*.js", "vitest/**/*.{js,ts}"]
}
