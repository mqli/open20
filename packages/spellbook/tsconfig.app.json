{
  "extends": "@open20/config/tsconfig/react-app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": ["vite/client", "@testing-library/jest-dom"],

    /* Bundler mode */
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Path aliases */
    "paths": {
      "@open20/spellbook/*": ["./src/*"],
      "@open20/spellbook": ["./src/main.tsx"],
    },
  },
  "include": ["src"],
}
