{
  "name": "@open20/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./styles": "./dist/styles/design-tokens.js",
    "./*": "./dist/*"
  },
  "scripts": {
    "prepare": "pnpm run build",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "build-storybook": "CI=1 storybook build",
    "dev": "tsc --watch -p tsconfig.build.json & tsc-alias --watch -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "catalog:",
    "@radix-ui/react-dropdown-menu": "catalog:",
    "@radix-ui/react-select": "catalog:",
    "@radix-ui/react-slider": "catalog:",
    "@radix-ui/react-switch": "catalog:",
    "@radix-ui/react-tabs": "catalog:",
    "@radix-ui/react-toggle": "catalog:",
    "@radix-ui/react-tooltip": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "lucide-react": "catalog:",
    "open20-core": "workspace:*",
    "tailwind-merge": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@open20/config": "workspace:*",
    "@storybook/addon-essentials": "catalog:",
    "@storybook/addon-links": "catalog:",
    "@storybook/react": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "autoprefixer": "catalog:",
    "postcss": "catalog:",
    "storybook": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "tsc-alias": "^1.8.17",
    "eslint": "catalog:",
    "prettier": "^3.8.3"
  }
}
