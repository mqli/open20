{
  "name": "open20-core",
  "version": "0.2.1",
  "description": "DND 2024 Character Sheet — Headless Core (TypeScript, zero UI dependency)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/types/index.js",
    "./data": "./dist/data/index.js",
    "./engine": "./dist/engine/index.js",
    "./character": "./dist/character/index.js",
    "./spells": "./dist/spells/index.js",
    "./monster": "./dist/monster/index.js",
    "./content": "./dist/content/index.js",
    "./rolls": "./dist/rolls/index.js",
    "./dice": "./dist/dice/index.js",
    "./storage": "./dist/storage/index.js",
    "./static/*": "./static/*"
  },
  "scripts": {
    "prepare": "pnpm run build",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "build:bundle": "pnpm run build && pnpm run bundle",
    "bundle": "node scripts/bundle.mjs",
    "dev": "tsc --watch -p tsconfig.build.json & tsc-alias --watch -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:artifact": "pnpm run build && vitest run --config vitest.artifact.config.ts",
    "test:browser-artifact": "pnpm run build:bundle && vitest run --config vitest.browser.config.ts",
    "test:all": "pnpm run test && pnpm run test:artifact && pnpm run test:browser-artifact",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry-run"
  },
  "keywords": [
    "dnd",
    "dnd2024",
    "character-sheet",
    "typescript",
    "headless"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mqli/open20.git"
  },
  "files": [
    "dist/",
    "static/",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "devDependencies": {
    "@open20/config": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "prettier": "catalog:",
    "tsc-alias": "catalog:",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vitest": "catalog:",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=18"
  }
}
