{
  "extends": "@open20/config/tsconfig/library.json",
  "compilerOptions": {
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "paths": {
      "@open20/core/*": ["./src/*"],
      "@open20/core": ["./src/index.ts"],
    },
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"],
}
